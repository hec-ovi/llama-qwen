# Copy to .env and fill in.
#
# Only LLAMA_HOST_MODELS_DIR is strictly required.
# Everything else has a sensible default.

# Absolute host path to your HuggingFace model cache directory.
# Must contain hub/ subdirectory with the GGUF snapshot already
# fetched (e.g. via `hf download unsloth/Qwen3.6-27B-GGUF --cache-dir $LLAMA_HOST_MODELS_DIR/hub`).
LLAMA_HOST_MODELS_DIR=/absolute/path/to/hf-cache

# HuggingFace token. Needed by `hf download` at cache-fill time.
# Unsloth's Qwen3.6-27B-GGUF is NOT gated (public), so this is only
# required if you're rate-limited as anonymous or want faster pulls.
# Mint a read token at https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here

# Loopback-only host port. Change if 8080 is taken.
LLAMA_HOST_PORT=8080

# Path to the GGUF file inside the container (i.e. under /models/...).
# Default points at Unsloth's Q8_0 for Qwen 3.6 27B. The snapshot sha
# in the default is pinned to the version in use at the time of the
# last bench run — `hf download` will create its own snapshot dir with
# a different sha, so update this to match after downloading.
LLAMA_MODEL_FILE=/models/hub/models--unsloth--Qwen3.6-27B-GGUF/snapshots/82d411acf4a06cfb8d9b073a5211bf410bfc29bf/Qwen3.6-27B-Q8_0.gguf

# Max context window. Native max for Qwen 3.6 27B is 262144 (256K).
# Reducing this does save KV-cache RAM on llama.cpp (unlike vLLM);
# 262144 with q8_0 KV fits comfortably in a 128 GB UMA.
LLAMA_CONTEXT=262144

# Decode threads. Strix Halo has 16 physical p-cores.
LLAMA_THREADS=16

# Prefill threads. Prefill is CPU-parallel; use full SMT (32 on 16c/32t).
LLAMA_THREADS_BATCH=32
